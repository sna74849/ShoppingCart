@using ShoppingCart.Models.Dtos
@using ShoppingCart.Models.ViewModels
@{
    ViewData["Title"] = "Cart";
}
@model List<CartItemViewModel>

<h1>カート </h1>
<div class="container">
    <a href="../items">&lt;&emsp;商品一覧へ</a>
    <div id="cart-container" class="mt-3">
        <!-- カートの内容はJSで動的に生成 -->
    </div>
</div>
@section Scripts {
    <script>
        // サーバー側の Model を JS に渡す
        const initialCartData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));

        // ページロード時に renderCart を実行
        document.addEventListener("DOMContentLoaded", () => {
            renderCart(initialCartData);
        });


        // HTMLではGETとPOSTしか選べないためJSの非同期処理で対応
        document.body.addEventListener('click', async (event) => {
            if (event.target.matches('.delete-btn')) {
                fetchAndResponse(event);
            }
        });

        document.body.addEventListener('change', async (event) => {
            if (event.target.matches('.qty-select')) {
                fetchAndResponse(event);
            }
        });

        async function fetchAndResponse(event) {
            const target = event.target;
            // buttonから一番近い.cart-formを探す
            const form = target.closest('.cart-form');
            const janCd = form.querySelector('.jan-cd-input').value;
            // 数量が必要なのは更新時だけ
            let qty = 0;
            if (target.matches('.qty-select')) {
                qty = form.querySelector('.qty-select').value;
            }

            try {
                let response = null;
                if (target.matches('.qty-select')) {
                    response = await fetch(`/cart/items/${janCd}`, {
                        method: 'PUT',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded'
                        },
                        body: new URLSearchParams({ qty })
                    });
                } else {
                    response = await fetch(`/cart/items/${janCd}`, {
                        method: 'DELETE'
                    });
                }

                if (response.ok) {
                    const cartItemDtoList = await response.json();
                    console.log(cartItemDtoList);
                    renderCart(cartItemDtoList);
                } else {
                    alert(response.status + ": カート操作で問題が発生しました。在庫が既にない可能性があります。再度操作を試してください。");
                }
            } catch (error) {
                console.error('更新エラー:', error);
                alert('更新エラーが発生しました。');
            }
        }

        function renderCart(cartItemDtoList) {
            const cartContainer = document.querySelector("#cart-container");
            cartContainer.innerHTML = "";
            if (!cartItemDtoList || cartItemDtoList.length === 0) {
                cartContainer.innerHTML = "<p>カートは空です。</p>";
                return;
            }

            let total = 0;

            cartItemDtoList.forEach(itemDto => {
                const item = itemDto.Item;
                const qty = itemDto.InCartQty;
                const rowDiv = document.createElement("div");
                rowDiv.classList.add("row", "m-1");

                const leftDiv = document.createElement("div");
                leftDiv.classList.add("col-md-6", "bg-light", "p-1");
                leftDiv.innerHTML = `<img src="${item.FilePath}" class="w-75" />`;

                const rightDiv = document.createElement("div");
                rightDiv.classList.add("col-md-6", "bg-light", "text-center", "p-1");

                const formHtml = document.createElement("div");
                formHtml.innerHTML = `
                    <h2>${item.ItemNm}</h2>
                    <h9>JANコード：${item.JanCd}</h9>
                    <hr class="m-4" />
                    <p>${Number(item.Price).toLocaleString()} 円</p>
                    <div class="row bottom-0">
                        <form class="cart-form">
                            <select name="qty" class="qty-select"></select>
                            <input type="hidden" name="janCd" value="${item.JanCd}" class="jan-cd-input">
                            <button type="button" class="btn btn-link delete-btn">削除</button>
                        </form>
                    </div>
                `;
                rightDiv.appendChild(formHtml);

                const select = rightDiv.querySelector(".qty-select");
                for (let i = 1; i <= item.Qty; i++) {
                    const option = document.createElement("option");
                    option.value = i;
                    option.text = i;
                    if (i === qty) option.selected = true;
                    select.appendChild(option);
                }

                rowDiv.appendChild(leftDiv);
                rowDiv.appendChild(rightDiv);
                cartContainer.appendChild(rowDiv);

                total += Number(item.Price) * qty;
            });

            const totalDiv = document.createElement("h3");
            totalDiv.classList.add("col-md-12", "d-flex", "justify-content-end");
            totalDiv.innerHTML = `小計：${total.toLocaleString()}`;
            cartContainer.appendChild(totalDiv);

            const registerDiv = document.createElement("div");
            registerDiv.classList.add("text-center");
            registerDiv.innerHTML = `<a href="../register" class="btn-lg btn-warning text-white text-decoration-none">レジへ</a>`;
            cartContainer.appendChild(registerDiv);
        }
    </script>
}
